  "private": true,
  "main": "dist/apps/postybirb/main.js",
  "scripts": {
    "nx": "nx",
    "start": "nx run-many -t serve --projects=postybirb,postybirb-ui --parallel",
    "build": "nx run-many -t build --projects=postybirb,postybirb-ui --parallel",
    "build:prod": "nx run-many -t build --configuration=production --projects=postybirb,postybirb-ui --parallel",
    "lingui:extract": "lingui extract --clean",
    "make": "electron-builder install-app-deps && electron-builder -w portable",
    "electron-builder": "electron-builder",
    "dist": "yarn build:prod && electron-builder install-app-deps && electron-builder",
    "dist:win": "yarn build:prod && electron-builder install-app-deps && electron-builder --win",
    "dist:mac": "yarn build:prod && electron-builder install-app-deps && electron-builder --mac",
    "dist:linux": "yarn build:prod && electron-builder install-app-deps && electron-builder --linux",
    "test:client-server": "yarn rebuild && nx test client-server --codeCoverage=true && rimraf test",
    "test": "yarn rebuild && nx run-many -t test --parallel",
    "lint": "nx run-many -t lint --parallel --fix",
    "format": "prettier -w apps libs",
    "typecheck": "nx run-many -t typecheck",
    "affected:build": "nx affected: -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint --parallel",
    "affected:typecheck": "nx affected -t typecheck",
    "affected:dep-graph": "nx affected:dep-graph",
    "affected": "nx affected",
    "update": "nx migrate latest",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "postinstall": "exitzero yarn husky",
    "setup": "run-s setup:husky",
    "setup:husky": "yarn husky",
    "generate:sql": "drizzle-kit generate",
    "inject:app-insights": "node scripts/inject-app-insights.js",
    "inject:app-insights:clear": "node scripts/inject-app-insights.js --clear"
  },
